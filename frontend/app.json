{
  "expo": {
    "name": "HoseoLife",
    "slug": "hoseolife",
    "extra": {
      "eas": {
        "projectId": "b046f9bf-ef7a-4bd4-a9d0-74602416e381"
      }
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hoseolife",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "HoseoLife가 위치 정보를 사용하여 주변 게시글을 표시합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "buildNumber": "14",
      "config": {
        "googleMapsApiKey": "your-google-maps-api-key"
      },
      "bundleIdentifier": "com.dlckdfuf.camsaw",
      "googleServicesFile": "./ios/CamSaw/GoogleService-Info.plist",
        "associatedDomains": [
    "applinks:hoseolife.kro.kr/chat/rooms/share",
    "applinks:hoseolife.kro.kr/posts/share"
  ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "HoseoLife는 게시글에 사진을 업로드하기 위해 사진 라이브러리에 접근합니다.",
        "NSCameraUsageDescription": "HoseoLife는 게시글에 사진을 촬영하여 업로드하기 위해 카메라에 접근합니다.",
        "NSLocationWhenInUseUsageDescription": "HoseoLife는 주변 게시글을 표시하기 위해 위치 정보를 사용합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "HoseoLife는 주변 게시글을 표시하기 위해 위치 정보를 사용합니다.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsArbitraryLoadsInWebContent": true,
          "NSExceptionDomains": {
            "camsaw.kro.kr": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionMinimumTLSVersion": "1.0",
              "NSExceptionRequiresForwardSecrecy": false,
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "hoseolife.kro.kr": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionMinimumTLSVersion": "1.0",
              "NSExceptionRequiresForwardSecrecy": false,
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "your-server-ip": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionMinimumTLSVersion": "1.0",
              "NSExceptionRequiresForwardSecrecy": false,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.dlckdfuf.camsaw",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
                        "data": [
                {
                  "scheme": "https",
                  "host": "hoseolife.kro.kr",
                  "pathPrefix": "/chat/rooms/share"
                },
                {
                  "scheme": "https",
                  "host": "hoseolife.kro.kr",
                  "pathPrefix": "/posts/share"
                },
                {
                  "scheme": "hoseolife",
                  "host": "post"
                }
              ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_ANDROID_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "HoseoLife가 위치 정보를 사용하여 주변 게시글을 표시합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },
    "owner": "leechangryeol"
  }
}
